{
  "name": "@lifeforge/server",
  "private": true,
  "description": "The backend server for the LifeForge system",
  "version": "0.0.0",
  "license": "CC BY-NC-SA 4.0",
  "author": "LifeForge (https://github.com/LifeForge-app)",
  "homepage": "https://docs.lifeforge.melvinchia.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/LifeForge-app/lifeforge.git",
    "directory": "server"
  },
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc -b && vite build",
    "start": "tsc -b && NODE_ENV=production tsx ./src/index.ts",
    "start:prod": "NODE_ENV=production node --env-file=../../env/.env.local ./dist/server.js",
    "start:watch": "NODE_ENV=production node --watch --env-file=../../env/.env.local ./dist/server.js",
    "dev": "tsx watch ./src/index.ts",
    "lint": "eslint ./src --fix && prettier --write ./src",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@lifeforge/log": "workspace:*",
    "@lifeforge/pocketbase": "workspace:*",
    "@lifeforge/server-utils": "workspace:*",
    "@types/multer": "^2.2.0",
    "arctic": "^3.7.0",
    "argon2": "^0.44.0",
    "bcryptjs": "^3.0.2",
    "chalk": "^5.4.1",
    "commander": "^15.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "groq-sdk": "^1.3.0",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "node-cache": "^5.1.2",
    "openai": "^6.7.0",
    "pdf2pic": "^3.2.0",
    "pocketbase": "^0.27.0",
    "socket.io": "^4.8.1",
    "speakeasy": "^2.0.0",
    "tesseract.js": "^7.0.0",
    "uuid": "^14.0.1",
    "@typescript/typescript6": "^6.0.2"
  },
  "devDependencies": {
    "@lifeforge/api": "workspace:*",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.23",
    "@types/express-serve-static-core": "4.19.6",
    "@types/jsdom": "^28.0.3",
    "@types/morgan": "^1.9.9",
    "@types/speakeasy": "^2.0.10",
    "@vitest/ui": "^4.0.2",
    "axios": "^1.18.1"
  }
}
