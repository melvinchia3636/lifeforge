{
  "name": "lifeforge-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.13.0",
  "description": "A comprehensive self-hosted all-in-one personal management system",
  "version": "0.0.0",
  "license": "CC BY-NC-SA 4.0",
  "author": "LifeForge (https://github.com/LifeForge-app)",
  "homepage": "https://docs.lifeforge.melvinchia.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/LifeForge-app/lifeforge.git"
  },
  "workspaces": [
    "./apps/api",
    "./apps/web",
    "./docs",
    "./packages/*",
    "./modules/*",
    "./locales/*",
    "./tools"
  ],
  "scripts": {
    "forge": "tsx --tsconfig=$PWD/tools/tsconfig.json tools/src/index.ts",
    "build": "turbo build --filter=\"./packages/*\" && turbo build",
    "lint": "prettier --check . && eslint .",
    "fix": "prettier --write ./ && pnpm lint",
    "test": "turbo test",
    "postinstall": "turbo build --filter=\"./packages/*\"",
    "typecheck": "turbo typecheck"
  },
  "keywords": [
    "lifeforge"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lifeforge/configs": "workspace:*",
    "@originjs/vite-plugin-federation": "^1.4.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.21",
    "@types/opentype.js": "^1.3.10",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/tinycolor2": "^1.4.6",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "link:latest@typescript-eslint/eslint-plugin@latest",
    "@typescript-eslint/utils": "8.61.0",
    "@typescript/typescript6": "^6.0.2",
    "@vitejs/plugin-react": "^6.0.3",
    "argon2": "^0.44.0",
    "bcryptjs": "^3.0.3",
    "concurrently": "^10.0.3",
    "eslint": "^10.7.0",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-sonarjs": "^4.2.0",
    "eslint-plugin-unused-imports": "^4.2.0",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "pocketbase": "^0.27.0",
    "prettier": "^3.8.0",
    "turbo": "^2.0.4",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.31.1",
    "vite": "^8.1.5",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.90.2",
    "@uidotdev/usehooks": "^2.4.1",
    "@vanilla-extract/css": "^1.20.1",
    "@vanilla-extract/vite-plugin": "^5.2.2",
    "i18next-http-backend": "^2.7.3",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3",
    "i18next": "^26.3.6",
    "lodash": "^4.17.21",
    "nuqs": "^2.7.1",
    "opentype.js": "^2.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.77.0",
    "react-i18next": "^17.0.10",
    "react-router": "^8.2.0",
    "tinycolor2": "^1.6.0",
    "tsx": "^4.23.1",
    "zod": "4.3.5"
  }
}
