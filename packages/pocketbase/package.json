{
  "name": "@lifeforge/pocketbase",
  "version": "0.0.1",
  "description": "PocketBase types, interfaces, and PBService implementation for LifeForge",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && vite build && tsc --emitDeclarationOnly",
    "typecheck": "tsc --emitDeclarationOnly"
  },
  "dependencies": {
    "@lifeforge/log": "workspace:*",
    "@types/node": "^25.9.5",
    "chalk": "^5.6.2",
    "pocketbase": "^0.27.0"
  }
}
